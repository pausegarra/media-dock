{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pullyt",
  "version": "1.1.0",
  "identifier": "com.pausegarra.pullyt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "./ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pullyt - YouTube Downloader",
        "width": 800,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "assets/icons/windows/app.ico",
      "assets/icons/macos/AppIcon.icns",
      "assets/icons/linux/hicolor/512x512/apps/pullyt.png"
    ],
    "category": "Utility",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExNUUwNjEzM0QzQjNBMTAKUldRUU9qczlFd1plb1Jrb2l4K0xISEdsbEhCZnpjL2JiYXZnNGpYTWNDQnB1Z1FTQzVnWkZsZTgK",
      "endpoints": ["https://github.com/pausegarra/pullyt/releases/latest/download/latest.json"]
    }
  }
}
