<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Media Dock"
    UpgradeCode="a5f8af2b-ef89-4588-a2b5-f2b7924691d6"
    Version="$(env.ProductVersion)"
    Language="1033"
    Manufacturer="pausegarra">

    <Package
      Id="*"
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="ProductIcon" SourceFile="assets\icons\windows\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />

    <Property Id="ARPNOMODIFY" Value="yes" />
    <Property Id="ARPNOREPAIR" Value="yes" />
    <Property Id="ARPHELPLINK" Value="https://github.com/pausegarra/media-dock" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/pausegarra/media-dock" />

    <Feature Id="ProductFeature" Title="Media Dock" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Media Dock" />
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Media Dock" />
      </Directory>

      <Directory Id="DesktopFolder" />
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents">
      <Component Id="MediaDockExeComponent" Directory="INSTALLFOLDER" Guid="e2acf926-bb4b-463e-b660-eb4dfd18f422">
        <File
          Id="MediaDockExe"
          Source="target\x86_64-pc-windows-msvc\release\media-dock.exe"
          KeyPath="yes" />

        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Directory="ApplicationProgramsFolder"
          Name="Media Dock"
          Description="Media Dock"
          Target="[INSTALLFOLDER]media-dock.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="ProductIcon"
          IconIndex="0" />
      </Component>

      <Component Id="ApplicationProgramsFolderComponent" Directory="ApplicationProgramsFolder" Guid="6e132fac-6f0c-4a1a-a3bd-0fb92d35bc44d">
        <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\pausegarra\Media Dock"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>